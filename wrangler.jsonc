{
  // Cloudflare Pages 設定 (静的アセット配信 + Functions によるAPI)
  // 画面は dist/client をPagesが直接配信し、/api/* は functions/ が処理する。
  "name": "inhouse-portal",
  "pages_build_output_dir": "dist/client",
  "compatibility_date": "2026-06-01"
  // GASエンドポイントの実URLはリポジトリに書かず、Pagesの環境変数(secret)
  // PROXY_TARGETS に登録する:
  //   npx wrangler pages secret put PROXY_TARGETS
  // 例: {"kintai-api":"https://script.google.com/macros/s/XXXX/exec"}
}
